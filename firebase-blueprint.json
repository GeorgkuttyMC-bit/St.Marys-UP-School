{
  "entities": {
    "Student": {
      "title": "Student",
      "description": "A student in the school.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        }
      },
      "required": ["name"]
    },
    "Mark": {
      "title": "Mark",
      "description": "A mark entry for a student.",
      "type": "object",
      "properties": {
        "studentId": {
          "type": "string"
        },
        "examName": {
          "type": "string"
        },
        "subject": {
          "type": "string"
        },
        "mark": {
          "type": "number"
        },
        "maxMark": {
          "type": "number"
        }
      },
      "required": ["studentId", "examName", "subject", "mark", "maxMark"]
    },
    "Attendance": {
      "title": "Attendance",
      "description": "An attendance entry for a student.",
      "type": "object",
      "properties": {
        "studentId": {
          "type": "string"
        },
        "date": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": ["present", "absent"]
        }
      },
      "required": ["studentId", "date", "status"]
    }
  },
  "firestore": {
    "/students/{studentId}": {
      "schema": "Student",
      "description": "Stores student records."
    },
    "/marks/{markId}": {
      "schema": "Mark",
      "description": "Stores mark entries for students."
    },
    "/attendance/{attendanceId}": {
      "schema": "Attendance",
      "description": "Stores daily attendance for students."
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    match /students/{studentId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null 
        && request.resource.data.keys().hasAll(['name']) 
        && request.resource.data.keys().size() == 1
        && request.resource.data.name is string 
        && request.resource.data.name.size() > 0;
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name'])
        && request.resource.data.name is string 
        && request.resource.data.name.size() > 0;
      allow delete: if request.auth != null;
    }

    match /marks/{markId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll(['studentId', 'examName', 'subject', 'mark', 'maxMark'])
        && request.resource.data.keys().size() == 5
        && request.resource.data.studentId is string
        && request.resource.data.examName is string
        && request.resource.data.subject is string
        && request.resource.data.mark is number
        && request.resource.data.maxMark is number;
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['mark', 'maxMark', 'studentId', 'examName', 'subject'])
        && request.resource.data.mark is number
        && request.resource.data.maxMark is number;
      allow delete: if request.auth != null;
    }

    match /attendance/{attendanceId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll(['studentId', 'date', 'status'])
        && request.resource.data.keys().size() == 3
        && request.resource.data.studentId is string
        && request.resource.data.date is string
        && request.resource.data.status is string
        && request.resource.data.status in ['present', 'absent'];
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
        && request.resource.data.status is string
        && request.resource.data.status in ['present', 'absent'];
      allow delete: if request.auth != null;
    }
  }
}